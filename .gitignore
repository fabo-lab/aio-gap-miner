# Byte-compiled / optimized
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# Secrets & credentials — NEVER commit these
.env
.env.*
!.env.example
*.key
secrets.*

# Real query lists are personal/business research (competitive keyword data) --
# keep private. The illustrative example stays public.
queries_*.txt
!queries.example.txt

# Tableau exports of REAL data (per-row query/URL detail) stay private -- ALWAYS
# export real-data runs to a "real_"-prefixed filename (see README), never onto
# the tracked synthetic demo file, so this pattern can never accidentally un-ignore it.
tableau/real_*.csv

# Jupyter
.ipynb_checkpoints/

# Data: raw and processed data stay local. The synthetic sample IS committed
# (see data/sample/) so the repo runs out of the box.
data/raw/*
data/processed/*
data/*.db
!data/raw/.gitkeep
!data/processed/.gitkeep

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
collect_log.txt
collect_log*.txt

# Analysis outputs with per-row query/URL/content detail stay private.
# Aggregate summaries and charts stay public - they are the findings.
reports/results/serp_features_enriched.csv
reports/results/paa_questions.csv
reports/results/paa_clusters.csv
reports/results/paa_top_questions.csv
reports/results/aio_text.csv
reports/results/aio_citations_detail.csv
reports/results/aio_source_overlap.csv
reports/results/aio_overlap_summary.csv
reports/results/passage_matches.csv
reports/results/passage_patterns.csv
reports/results/query_segments.csv
reports/results/html_position.csv
tableau/tableau_*.csv
