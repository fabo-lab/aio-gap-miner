# Byte-compiled / optimized
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# Secrets & credentials — NEVER commit these
.env
.env.*
!.env.example
*.key
secrets.*

# Real query lists are personal/business research (competitive keyword data) --
# keep private. The illustrative example stays public.
queries_*.txt
!queries.example.txt

# Tableau exports of REAL data (per-row query/URL detail) stay private -- ALWAYS
# export real-data runs to a "real_"-prefixed filename (see README), never onto
# the tracked synthetic demo file, so this pattern can never accidentally un-ignore it.
tableau/real_*.csv

# Jupyter
.ipynb_checkpoints/

# Data: raw and processed data stay local. The synthetic sample IS committed
# (see data/sample/) so the repo runs out of the box.
data/raw/*
data/processed/*
data/*.db
!data/raw/.gitkeep
!data/processed/.gitkeep

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
collect_log.txt
collect_log*.txt
