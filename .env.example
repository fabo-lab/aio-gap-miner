# Copy this file to `.env` and fill in your real credentials.
# `.env` is git-ignored and must NEVER be committed. This template (.env.example)
# is safe to commit because it contains no real values.

# DataForSEO API (https://app.dataforseo.com/api-access) — HTTP Basic auth
DATAFORSEO_LOGIN=your_login_here
DATAFORSEO_PASSWORD=your_password_here

# Optional — Moz API token, for real domain_rating / page_authority features
# MOZ_TOKEN=your_moz_token_here
